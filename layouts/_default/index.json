{{- $pages := where site.RegularPages "Type" "in" site.Params.mainSections -}}
{{- $pages = where $pages "Params.searchHidden" "!=" true -}}
{{- $pages = where $pages "Layout" "!=" "archives" -}}
{{- $pages = where $pages "Layout" "!=" "search" -}}
{{- $index := slice -}}
{{- range $pages -}}
{{- $summary := .Description | default (.Summary | plainify | htmlUnescape) | strings.TrimSpace | truncate 220 -}}
{{- $tags := .Params.tags | default (slice) -}}
{{- $categories := .Params.categories | default (slice) -}}
{{- $keywords := .Params.keywords | default (slice) -}}
{{- $index = $index | append (dict
  "title" .Title
  "permalink" .RelPermalink
  "summary" $summary
  "tags" $tags
  "categories" $categories
  "keywords" $keywords
  "section" .Section
  "date" (.Date.Format "2006-01-02T15:04:05Z07:00")
  "lastmod" (.Lastmod.Format "2006-01-02T15:04:05Z07:00")
) -}}
{{- end -}}
{{- $index | jsonify -}}
